# .gitignore file for ONTeater NextFlow pipeline

# Ignore all hidden files in root directory
/.*

# Explicitly include the base directory's '.gitignore' as an exception - you want git to track that one
!/.gitignore
plugins/

# Ignore NextFlow's 'work' and 'results' directories
/work
/results
./plugins/* 



# Ignore fasta_QC (auto-generated with operation, not needed for git purposes
/fasta_QC

# Ignore large .fa files - can't load anything bigger than 100MB to GitHbu
