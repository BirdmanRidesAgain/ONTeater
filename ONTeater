#!/usr/bin/env python3
# -*- coding: utf-8 -*-

from argparse import ArgumentParser
import subprocess
import sys

DEFAULT_CONTAINER_IMAGE = "oneteater:1.0.0-amd64"


def main():
    parser = ArgumentParser(description="Run the ONTeater Nextflow pipeline.")
    parser.add_argument("-o", "--ONT_rds", type=str, help="Path to ONT reads.")
    parser.add_argument("-gs", "--genome_size", type=str)
    parser.add_argument("-b", "--BUSCO_lineage", type=str)
    parser.add_argument("-t", "--threads", type=int)
    parser.add_argument("-w", "--workflow", type=str, default="run")
    parser.add_argument("--flye_asm", type=str)
    parser.add_argument("--nd_asm", type=str)
    parser.add_argument("--final_asm", type=str)
    parser.add_argument("-pro", "--profile", type=str)
    parser.add_argument("--trace", type=str)
    parser.add_argument("--report", type=str)
    parser.add_argument("-pre", "--prefix", type=str, default="out")
    parser.add_argument(
        "--container_image",
        type=str,
        help=f"Docker image tag (with -profile docker). Default: {DEFAULT_CONTAINER_IMAGE}",
    )
    parser.add_argument("--stub", action="store_true", help="Run Nextflow in native stub mode (-stub-run).")
    parser.add_argument("--resume", action="store_true")
    args = parser.parse_args()

    workflow_mode = str(args.workflow)
    ont_reads = args.ONT_rds

    if workflow_mode in {"run", "trim", "assemble"} and not ont_reads:
        parser.error("Provide ONT reads via --ONT_rds.")
    if workflow_mode in {"run", "trim", "assemble"}:
        if args.genome_size is None:
            parser.error(f"--genome_size is required for workflow '{workflow_mode}'.")
        if args.BUSCO_lineage is None:
            parser.error(f"--BUSCO_lineage is required for workflow '{workflow_mode}'.")
    if workflow_mode == "postprocess" and (args.flye_asm is None or args.nd_asm is None):
        parser.error("--flye_asm and --nd_asm are required for workflow 'postprocess'.")
    if workflow_mode == "qc" and args.final_asm is None:
        parser.error("--final_asm is required for workflow 'qc'.")

    cmd = [
        "nextflow",
        "run",
        "main.nf",
        "--workflow",
        workflow_mode,
        "--prefix",
        str(args.prefix),
    ]

    if ont_reads:
        cmd.extend(["--ONT_rds", ont_reads])
    if args.genome_size is not None:
        cmd.extend(["--genome_size", str(args.genome_size)])
    if args.BUSCO_lineage is not None:
        cmd.extend(["--BUSCO_lineage", str(args.BUSCO_lineage)])
    if args.flye_asm:
        cmd.extend(["--flye_asm", str(args.flye_asm)])
    if args.nd_asm:
        cmd.extend(["--nd_asm", str(args.nd_asm)])
    if args.final_asm:
        cmd.extend(["--final_asm", str(args.final_asm)])

    if args.threads is not None:
        cmd.extend(["--threads", str(args.threads)])
    profile_str = str(args.profile) if args.profile else ""
    profiles = [p.strip() for p in profile_str.split(",") if p.strip()]
    using_docker_profile = "docker" in profiles

    if args.profile:
        cmd.extend(["-profile", str(args.profile)])

    if args.container_image and not using_docker_profile:
        print(
            "WARNING: --container_image is only used with the docker profile.",
            file=sys.stderr,
        )

    if using_docker_profile:
        # Always pass a concrete image for docker profile runs so wrapper behavior
        # remains stable even if config resolution varies across environments.
        container_image = args.container_image or DEFAULT_CONTAINER_IMAGE
        cmd.extend(["--container_image", str(container_image)])
    if args.stub:
        cmd.append("-stub-run")
    if args.trace:
        cmd.extend(["-with-trace", str(args.trace)])
    if args.report:
        cmd.extend(["-with-report", str(args.report)])
    if args.resume:
        cmd.append("-resume")

    subprocess.run(cmd, check=False)

# If this is being imported
if __name__=="__main__":
    main()