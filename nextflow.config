manifest {
    author = 'Keiler Collier'
    description = 'This is a NextFlow script designed to automatically run the ONTeater assembly pipeline. Currently, it will be used to QC fastas.'
    mainScript = 'ONTeater.nf'
    name = 'ONTeater'
    nextflowVersion = '>=23.10.1' //this is the version I initially developed it on
    version = '1.0.0'
}

// also suppliable via '-params-file' option in invocation
params {
    input_fasta = "$projectDir/*.{fa,fasta}"
    fasta_QC_dir = "fasta_QC"
    conda_env = "$projectDir/*.{yml,yaml}"
}


process.container = 'staphb/quast'

// we need to learn how to use quast with docker
//docker.runOptions = '-u $(id -u):$(id -g)'
//docker.enabled = true
conda.enabled = true
