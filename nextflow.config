manifest {
    author = 'Keiler Collier'
    description = 'This is a NextFlow script designed to automatically run the ONTeater assembly pipeline.'
    mainScript = 'ONTeater.nf'
    name = 'ONTeater'
    nextflowVersion = '>=23.10.1' //this is the version of NextFlow I initially developed the pipeline on. It might work for others.
    version = '1.0.0'
}

params {
// Params for upper-resource limits:
    max_cpus = Runtime.runtime.availableProcessors()
    totalMemoryGB = Runtime.runtime.maxMemory() / 1024 / 1024 / 1024 
    memoryToUseGB = (totalMemoryGB * 0.8).round(2)

// Workflow params
    workflow = "run"

//input params
    ONT_raw = null
    PB_raw = null
    shortreads_raw = "$projectDir/*{1,2}.fq.gz" //shortreads have variable name formats, but always contain a 1 or 2 element
    // These are included so I know how to provide intermediate steps later
    flye_asm = null
    nd_asm =  null
    
    nextdenovo_conf = "$projectDir/nd_run.cfg"
    genome_size = 1
    BUSCO_lineage = null

    results_dir = "results" 
    workdir = './'
}

process {
    resourceLimits = [ cpus: params.max_cpus, memory: params.memoryToUseGB, time: 72.h ]
}

// we need to learn how to use quast with docker
//docker.runOptions = '-u $(id -u):$(id -g)'
//docker.enabled = true
conda.enabled = true
report.overwrite = true

plugins {
    id 'nf-prov@1.1.0'
}