manifest {
    author = 'Keiler Collier'
    description = 'This is a NextFlow script designed to automatically run the ONTeater assembly pipeline.'
    mainScript = 'main.nf'
    name = 'ONTeater'
    nextflowVersion = '>=25.10' //This is the earliest NextFlow where workflow outputs are out of testing.
    version = '1.0.0'
}

cleanup = true

workflow {
    output.mode = 'copy'
}

params {
// Params for upper-resource limits:
    max_cpus = Runtime.runtime.availableProcessors()
    totalMemoryGB = Runtime.runtime.maxMemory() / 1024d / 1024d / 1024d
    memoryToUseGB = ((Runtime.runtime.maxMemory() / 1024d / 1024d / 1024d) * 0.8).round(2)

// workflow params
    workflow = "run"

//input params
    help = false
    prefix = 'out'
    threads = Runtime.runtime.availableProcessors().intdiv(2)
    ONT_rds = null
    ONT_raw = null
    //PB_rds = null
    //short_rds = null
    nextdenovo_conf = "$projectDir/bin/nd_run.cfg"
    genome_size = null
    BUSCO_lineage = null
    flye_asm = null
    nd_asm = null
    final_asm = null
    qc_stub = false
    polish_stub = false

    // Docker profile: image tag or registry path (override on CLI: --container_image my/oneteater:1.0.0)
    container_image = 'oneteater:1.0.0'

    //non-user facing parameters:
    outdir = params.prefix
}

process {
    resourceLimits = [ cpus: params.max_cpus, memory: params.memoryToUseGB, time: 72.h ]
}

//defines execution profiles for different environments
profiles {
    // Default: per-process conda (portable, but solver-sensitive).
    standard {
        conda.enabled = true
        conda.cacheDir = "${launchDir}/conda_cache"
        conda.channels = ['bioconda', 'conda-forge']
        report.overwrite = true
        process {
            conda = 'nanoplot chopper nanofilt'
        }
    }

    // Explicit alias for conda-on-host runs (same as standard).
    conda {
        conda.enabled = true
        conda.cacheDir = "${launchDir}/conda_cache"
        conda.channels = ['bioconda', 'conda-forge']
        report.overwrite = true
        process {
            conda = 'nanoplot chopper nanofilt'
        }
    }

    // Reproducible runs: all processes in one container; per-process conda is disabled.
    docker {
        docker.enabled = true
        conda.enabled = false
        report.overwrite = true
        process {
            container = { params.container_image }
        }
    }

    qc_stub {
        conda.enabled = false
        params.qc_stub = true
    }
}
